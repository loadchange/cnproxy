{
  "name": "cnproxy",
  "version": "5.0.0",
  "description": "A modern HTTP/HTTPS/WebSocket debugging & MITM proxy for developers, built on Bun. Capture, inspect, rewrite and mock traffic with a live web inspector.",
  "author": "LoadChange <soocto@gmail.com>",
  "license": "MIT",
  "type": "module",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "bin": {
    "cnproxy": "bin/cnproxy.ts"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src",
    "bin"
  ],
  "scripts": {
    "start": "bun run bin/cnproxy.ts",
    "dev": "bun --watch run bin/cnproxy.ts",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "dependencies": {
    "node-forge": "^1.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-forge": "^1.3.11",
    "bun-types": "^1.3.14",
    "typescript": "^5.5.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LoadChange/cnproxy.git"
  },
  "keywords": [
    "proxy",
    "mitm",
    "http",
    "https",
    "websocket",
    "debugging",
    "capture",
    "fiddler",
    "charles",
    "whistle",
    "reqable",
    "bun"
  ]
}
