{
  "name": "cnproxy",
  "version": "5.0.0",
  "description": "Chipper Nut Proxy (cnproxy) — A modern HTTP/HTTPS/WebSocket debugging & MITM proxy for developers, built on Node.js.",
  "author": "LoadChange <soocto@gmail.com>",
  "license": "MIT",
  "type": "module",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "bin": {
    "cnproxy": "bin/cnproxy.ts"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src",
    "bin"
  ],
  "scripts": {
    "start": "tsx bin/cnproxy.ts",
    "dev": "tsx watch bin/cnproxy.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "gen:ui": "node scripts/embed-ui.mjs",
    "prebuild": "npm run gen:ui",
    "build": "node scripts/build.mjs",
    "build:sidecar": "bash scripts/build-sidecar.sh",
    "app:dev": "bash scripts/build-sidecar.sh && cd cnproxy-app && npx tauri dev",
    "app:build": "bash scripts/build-sidecar.sh && cd cnproxy-app && npx tauri build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "node-forge": "^1.3.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-forge": "^1.3.11",
    "@types/ws": "^8.5.12",
    "@yao-pkg/pkg": "^6.3.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LoadChange/cnproxy.git"
  },
  "keywords": [
    "proxy",
    "mitm",
    "http",
    "https",
    "websocket",
    "debugging",
    "capture",
    "fiddler",
    "charles",
    "whistle",
    "reqable",
    "node"
  ]
}
